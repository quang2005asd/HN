<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_loai_van_ban_tree" model="ir.ui.view">
        <field name="name">loai.van.ban.tree</field>
        <field name="model">loai.van.ban</field>
        <field name="arch" type="xml">
            <tree>
                <field name="ma_loai"/>
                <field name="name"/>
                <field name="mo_ta"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_loai_van_ban_form" model="ir.ui.view">
        <field name="name">loai.van.ban.form</field>
        <field name="model">loai.van.ban</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="ma_loai"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="mo_ta"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_loai_van_ban" model="ir.actions.act_window">
        <field name="name">Loại Văn Bản</field>
        <field name="res_model">loai.van.ban</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
