<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dashboard_form" model="ir.ui.view">
        <field name="name">dashboard.form</field>
        <field name="model">dashboard</field>
        <field name="arch" type="xml">
            <form string="Dashboard Tổng Quan" create="0" delete="0" edit="0">
                <sheet>
                    <div class="dashboard-shell premium-dashboard">
                        <div class="dashboard-hero-wrap">
                            <div class="oe_title dashboard-hero">
                                <h1>Dashboard Tổng Quan</h1>
                                <p>Trung tâm theo dõi khách hàng, chi tiêu và hiệu suất hỗ trợ theo thời gian thực.</p>
                            </div>
                            <div class="dashboard-kpi-grid">
                                <div class="kpi-card kpi-blue">
                                    <span class="kpi-label">Tổng khách hàng</span>
                                    <span class="kpi-value" id="kpiTotalCustomers">0</span>
                                </div>
                                <div class="kpi-card kpi-teal">
                                    <span class="kpi-label">Tổng chi tiêu</span>
                                    <span class="kpi-value" id="kpiTotalSpending">0 ₫</span>
                                </div>
                                <div class="kpi-card kpi-orange">
                                    <span class="kpi-label">Khu vực dẫn đầu</span>
                                    <span class="kpi-value" id="kpiTopRegion">--</span>
                                </div>
                                <div class="kpi-card kpi-indigo">
                                    <span class="kpi-label">Chi tiêu trung bình</span>
                                    <span class="kpi-value" id="kpiAvgSpending">0 ₫</span>
                                </div>
                                <div class="kpi-card kpi-gold">
                                    <span class="kpi-label">Khách VIP #1</span>
                                    <span class="kpi-value" id="kpiTopCustomer">--</span>
                                </div>
                                <div class="kpi-card kpi-emerald">
                                    <span class="kpi-label">NV hỗ trợ nổi bật</span>
                                    <span class="kpi-value" id="kpiTopSupport">--</span>
                                </div>
                            </div>
                        </div>

                        <div class="section-heading">
                            <h2>Biểu đồ khách hàng và chi tiêu theo vùng</h2>
                        </div>

                        <div class="dashboard-grid">
                            <div class="chart-card oe_box">
                                <h3>Phân bổ Khách Hàng</h3>
                                <canvas id="customerChart"></canvas>
                            </div>
                            <div class="chart-card oe_box">
                                <h3>Tổng Chi Tiêu</h3>
                                <canvas id="spendingChart"></canvas>
                            </div>
                        </div>

                        <div class="section-heading">
                            <h2>Xếp hạng khách hàng</h2>
                        </div>

                        <div class="oe_box full-width-card">
                            <h2>Biểu đồ xếp hạng khách hàng</h2>
                            <canvas id="rankingChart" width="400" height="200"></canvas>
                        </div>

                        <div class="oe_box full-width-card">
                            <h2>Bảng xếp hạng khách hàng</h2>
                            <table id="rankingTable" class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Hạng</th>
                                        <th>Khách Hàng</th>
                                        <th>Tổng Tiền Chi Tiêu</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>

                        <div class="section-heading">
                            <h2>Hiệu suất hỗ trợ nhân viên</h2>
                        </div>

                        <div class="oe_box full-width-card">
                            <h2>Biểu đồ thống kê hỗ trợ</h2>
                            <canvas id="supportChart" width="400" height="200"></canvas>
                        </div>

                        <div class="oe_box full-width-card">
                            <h2>Bảng thống kê hỗ trợ nhân viên</h2>
                            <table id="supportStatsTable" class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Nhân Viên</th>
                                        <th>Số Lần Hỗ Trợ</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">dashboard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_dashboard_form"/>
        <field name="target">current</field>  <!-- Đảm bảo mở lại trang hiện tại -->
    </record>



</odoo>
